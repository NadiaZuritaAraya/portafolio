# ── Firebase (frontend) ──────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── App ───────────────────────────────────────────────────────
VITE_APP_URL=https://tu-dominio.vercel.app

# ── Firebase Admin SDK (solo servidor — Vercel API Routes) ───
# Obtener en Firebase Console → Configuración → Cuentas de servicio → Generar clave privada
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Resend (envío de emails) ──────────────────────────────────
# Obtener en resend.com → API Keys
RESEND_API_KEY=
FROM_EMAIL=portafolio@tunombre.com
