rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Tokens: solo la Cloud Function (admin SDK) puede escribir.
    // El cliente puede leer para validar su propio token.
    match /access_tokens/{token} {
      allow read:  if true;
      allow write: if false;
    }

    // Solicitudes: el cliente puede crear (POST del form).
    // Solo admin puede leer/modificar.
    match /access_requests/{email} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Views: solo el admin SDK escribe (desde validateToken).
    match /portfolio_views/{id} {
      allow read, write: if false;
    }
  }
}
